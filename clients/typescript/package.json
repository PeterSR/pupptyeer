{
  "name": "pupptyeer-client",
  "version": "0.5.0",
  "description": "Thin Node client for the pupptyeer daemon (NDJSON over a unix socket).",
  "type": "module",
  "main": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    "types": "./index.d.ts",
    "default": "./index.mjs"
  },
  "files": ["index.mjs", "index.d.ts", "README.md", "LICENSE"],
  "scripts": {
    "smoke": "node smoke.mjs"
  },
  "keywords": ["pty", "terminal", "tty", "daemon", "ndjson", "pupptyeer"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterSR/pupptyeer.git",
    "directory": "clients/typescript"
  },
  "homepage": "https://github.com/PeterSR/pupptyeer/tree/main/clients/typescript#readme",
  "bugs": "https://github.com/PeterSR/pupptyeer/issues",
  "author": "PeterSR",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
